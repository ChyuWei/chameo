{
  "name": "chameo",
  "description": "查咩 - 网页英语学习助手，标注生词与语法结构",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "build:all": "wxt build && wxt build -b firefox && wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "zip:all": "wxt zip && wxt zip -b firefox && wxt zip -b edge",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.54",
    "@ai-sdk/google": "^3.0.37",
    "@ai-sdk/openai": "^3.0.39",
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@webext-core/messaging": "^2.3.0",
    "@webext-core/storage": "^1.2.0",
    "@wxt-dev/storage": "^1.2.8",
    "ai": "^6.0.111",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.8.13",
    "lucide-react": "^0.576.0",
    "p-limit": "^7.3.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "sentence-splitter": "^5.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  }
}
